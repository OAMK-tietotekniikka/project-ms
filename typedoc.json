{
  "entryPoints": ["server", "frontend"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "theme": "default",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "includeVersion": true,
  "sort": ["source-order"],
  "plugin": ["typedoc-material-theme"],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**"
  ],
  "tsconfig": "./tsconfig.json"
}